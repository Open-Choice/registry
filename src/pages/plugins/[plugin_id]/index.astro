---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import {
  loadManifest,
  loadEndpointHelp,
  listEndpoints,
  formatDate,
} from '../../../lib/loadData';

export async function getStaticPaths() {
  const { plugins } = loadManifest();
  return plugins.map((p) => ({ params: { plugin_id: p.plugin_id } }));
}

const { plugin_id } = Astro.params as { plugin_id: string };
const { plugins }   = loadManifest();
const plugin        = plugins.find((p) => p.plugin_id === plugin_id);

if (!plugin) {
  throw new Error(`Plugin not found in manifest: ${plugin_id}`);
}

const versions      = plugin.versions ?? [];
const latestVersion = plugin.latest_version;

const commands = listEndpoints(plugin_id, latestVersion);
const endpointSections = commands.map((command) => ({
  command,
  help: loadEndpointHelp(plugin_id, latestVersion, command),
}));

function renderNotes(md?: string): string {
  if (!md) return '';
  // Minimal markdown: ## headings, - bullets, **bold**. Mirrors the old generator.
  const esc = (s: string) => s
    .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
  const lines = md.split('\n');
  let out = '';
  let inList = false;
  const inline = (s: string) => esc(s).replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>');
  for (const raw of lines) {
    const t = raw.trimEnd();
    if (t.startsWith('## ')) {
      if (inList) { out += '</ul>'; inList = false; }
      out += `<h4>${inline(t.slice(3))}</h4>`;
    } else if (t.startsWith('- ') || t.startsWith('* ')) {
      if (!inList) { out += '<ul>'; inList = true; }
      out += `<li>${inline(t.slice(2))}</li>`;
    } else if (t === '') {
      if (inList) { out += '</ul>'; inList = false; }
    } else {
      if (inList) { out += '</ul>'; inList = false; }
      out += `<p>${inline(t)}</p>`;
    }
  }
  if (inList) out += '</ul>';
  return out;
}
---

<BaseLayout title={plugin.display_name}>
  <a slot="breadcrumb" href="/">Open Choice Registry</a>
  <span slot="breadcrumb" class="sep">/</span>
  <span slot="breadcrumb">{plugin.display_name}</span>

  <h1>{plugin.display_name}</h1>
  <p class="meta">
    {plugin.publisher} &mdash; Latest: v{plugin.latest_version}<br />
    <span class="plugin-id">{plugin.plugin_id}</span>
  </p>
  <p>{plugin.description}</p>
  <div class="cat-row">
    {(plugin.categories ?? []).map((c) => <span class="badge">{c}</span>)}
  </div>

  {endpointSections.length > 0 && (
    <>
      <h2>Endpoints</h2>
      <div class="endpoint-list">
        {endpointSections.map(({ command, help }) => (
          help ? (
            <a class="endpoint-card" href={`/plugins/${plugin.plugin_id}/${command}/`}>
              <h3>
                <code>{command}</code>
                {help.title && <span class="endpoint-title"> &mdash; {help.title}</span>}
              </h3>
              {help.summary && <p class="endpoint-summary">{help.summary}</p>}
            </a>
          ) : null
        ))}
      </div>
    </>
  )}

  <h2>Version History</h2>
  {versions.length === 0 && <p>No versions published yet.</p>}
  {versions.map((v, i) => {
    const isLatest = i === 0;
    const links = [];
    if (v.release_url)  links.push({ href: v.release_url,  text: 'GitHub Release →' });
    if (v.download_url) links.push({ href: v.download_url, text: 'Download .ocplugin' });
    const vCommands = listEndpoints(plugin_id, v.version);
    return (
      <div class="version-block" id={`v${v.version}`}>
        <h3>
          <a class="version-anchor" href={`/plugins/${plugin.plugin_id}/${v.version}/`}>v{v.version}</a>
          {isLatest && <span class="latest-tag">latest</span>}
          <span class="date">{formatDate(v.released_at)}</span>
        </h3>
        {v.release_notes && <div class="notes" set:html={renderNotes(v.release_notes)} />}
        {vCommands.length > 0 && (
          <div class="version-endpoints">
            <span class="version-endpoints-label">Endpoints:</span>
            {vCommands.map((cmd) => (
              <a
                class="version-endpoint-link"
                href={isLatest
                  ? `/plugins/${plugin.plugin_id}/${cmd}/`
                  : `/plugins/${plugin.plugin_id}/${v.version}/${cmd}/`}
              >
                <code>{cmd}</code>
              </a>
            ))}
          </div>
        )}
        {links.length > 0 && (
          <div class="links">
            {links.map((l) => <a href={l.href}>{l.text}</a>)}
          </div>
        )}
      </div>
    );
  })}
</BaseLayout>

<style>
  .meta { color: var(--oc-ink-soft); font-size: 0.9rem; margin-bottom: 1rem; }
  .plugin-id { font-size: 0.85rem; font-family: var(--oc-font-mono); }
  .cat-row { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
  .badge {
    background: var(--oc-brand-soft);
    color: var(--oc-brand-ink);
    border-radius: var(--oc-radius-sm);
    padding: 0.1rem 0.5rem;
    font-size: 0.8rem;
  }
  .endpoint-card {
    display: block;
    background: var(--oc-surface);
    border: 1px solid var(--oc-hairline);
    border-radius: var(--oc-radius);
    padding: 1rem 1.25rem;
    margin-bottom: 0.75rem;
    color: inherit;
    text-decoration: none;
    transition: border-color 0.15s, background 0.15s;
  }
  .endpoint-card:hover { border-color: var(--oc-accent); }
  .endpoint-card > h3 {
    font-size: 1.05rem;
    margin: 0 0 0.3rem;
    border: none;
    padding: 0;
  }
  .endpoint-card > h3 code { color: var(--oc-accent); }
  .endpoint-title { color: var(--oc-ink-soft); font-weight: 400; font-size: 0.95rem; }
  .endpoint-summary { color: var(--oc-ink-soft); margin: 0; font-size: 0.95rem; }

  .version-block {
    background: var(--oc-surface);
    border: 1px solid var(--oc-hairline);
    border-radius: var(--oc-radius);
    padding: 1rem 1.5rem;
    margin-bottom: 1rem;
  }
  .version-block h3 {
    margin: 0 0 0.25rem;
    font-size: 1rem;
    border: none;
    padding: 0;
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }
  .version-anchor {
    color: inherit;
    text-decoration: none;
  }
  .version-anchor:hover { text-decoration: underline; }
  .version-block .date { color: var(--oc-ink-soft); font-size: 0.85rem; font-weight: normal; }
  .version-block .notes { margin: 0.5rem 0 0.75rem; }
  .version-endpoints {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.35rem;
    margin: 0.5rem 0 0.75rem;
    font-size: 0.85rem;
  }
  .version-endpoints-label { color: var(--oc-ink-soft); margin-right: 0.1rem; }
  .version-endpoint-link {
    color: var(--oc-accent);
    text-decoration: none;
    padding: 0.1rem 0.45rem;
    border: 1px solid var(--oc-hairline);
    border-radius: var(--oc-radius-sm);
  }
  .version-endpoint-link:hover { border-color: var(--oc-accent); background: var(--oc-brand-soft); }
  .version-block .links { display: flex; gap: 1rem; font-size: 0.85rem; }
  .latest-tag {
    background: var(--oc-success-bg);
    color: var(--oc-success-fg);
    border-radius: var(--oc-radius-sm);
    padding: 0.1rem 0.45rem;
    font-size: 0.75rem;
    font-weight: 600;
  }
</style>
